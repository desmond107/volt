generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  avatar        String?
  kycStatus              String    @default("PENDING")
  kycLevel               Int       @default(0)
  failedLoginAttempts    Int       @default(0)
  loginLockedUntil       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  wallets       Wallet[]
  cards         VirtualCard[]
  transactions  Transaction[]
  kycDocuments  KycDocument[]
  apiKeys       ApiKey[]
}

model Wallet {
  id          String      @id @default(cuid())
  userId      String
  asset       String
  network     String
  address     String      @unique
  balance     Decimal     @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  cards        VirtualCard[]
}

model VirtualCard {
  id            String   @id @default(cuid())
  userId        String
  walletId      String?
  cardNumber    String   @unique
  cvv           String
  expiryMonth   Int
  expiryYear    Int
  cardHolder    String
  brand         String   @default("VISA")
  status        String   @default("ACTIVE")
  spendLimit    Decimal  @default(1000)
  spentAmount   Decimal  @default(0)
  balance       Decimal  @default(0)
  nfcEnabled    Boolean  @default(true)
  currency      String   @default("USD")
  label         String?
  color         String   @default("#6366f1")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet       Wallet?     @relation(fields: [walletId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  walletId      String?
  cardId        String?
  type          String
  status        String   @default("PENDING")
  amount        Decimal
  fee           Decimal  @default(0)
  currency      String   @default("USD")
  merchant      String?
  merchantLogo  String?
  category      String?
  description   String?
  reference     String   @unique @default(cuid())
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet?     @relation(fields: [walletId], references: [id])
  card   VirtualCard? @relation(fields: [cardId], references: [id])
}

model KycDocument {
  id          String   @id @default(cuid())
  userId      String
  docType     String
  docNumber   String?
  country     String?
  frontUrl    String?
  backUrl     String?
  selfieUrl   String?
  status      String   @default("PENDING")
  reviewNote  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  secret      String
  permissions String    @default("read")
  lastUsed    DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
